# ============================================
# Python Backend
# ============================================

# Bytecode / caches
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
.venv/
ENV/
env/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Environment files (CONTAINS JWT_SECRET, API KEYS - NEVER COMMIT)
.env
.env.local
.env.*.local

# ChromaDB persistent storage (regenerated by ingest script)
chroma_db/

# User database (passwords, emails — CRITICAL)
data/users.db
data/users.db-wal
data/users.db-shm
data/users.db-journal

# User-generated trip files
data/trips/

# Movement tracking data (future XGBoost integration)
data/movement/

# ML model binaries (allow JSON model files, block large binaries)
ml_models/*.pkl
ml_models/*.h5
ml_models/__pycache__/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/

# Logs
*.log
logs/